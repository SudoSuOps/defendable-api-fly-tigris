# defendable-api-fly-tigris · env example
# Copy to .env for local dev. In production, set via `fly secrets set`.

APP_ENV=development
APP_NAME=DefendableAPI
PORT=8080
UVICORN_WORKERS=2

# Postgres (Fly Managed Postgres attaches this automatically)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Tigris (Fly storage · S3-compatible)
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
TIGRIS_BUCKET=defendable-ledger

# API auth (Bearer token required for write/append routes; reads are public)
API_BEARER_TOKEN=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://defendableledger.com,https://defendabledocs.com,https://defendablerouter.com
